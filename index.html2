<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Muhammad Fakhri Almer Dzaky Portfolio</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <style>
        :root {
            --bg-dark: #12141d;
            --bg-card: #1c212e;
            --bg-contact-left: #252a37;
            --accent-green: #55f0b4; 
            --text-main: #ffffff;
            --text-dim: #a0a0a0;
            --glass: rgba(255, 255, 255, 0.03);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; scroll-behavior: smooth; }
        body { background-color: var(--bg-dark); color: var(--text-main); overflow-x: hidden; }

        /* --- Navbar --- */
        header {
            position: fixed; top: 0; width: 100%; padding: 20px 10%;
            display: flex; justify-content: space-between; align-items: center;
            background: rgba(18, 20, 29, 0.85); backdrop-filter: blur(15px); z-index: 1000;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        .logo { font-size: 1.6rem; font-weight: 800; letter-spacing: 1px; }
        .logo span { color: var(--accent-green); border-left: 3px solid var(--accent-green); padding-left: 10px; margin-left: 5px; }
        nav ul { display: flex; list-style: none; gap: 35px; }
        nav ul li a { text-decoration: none; color: var(--text-dim); font-size: 0.85rem; font-weight: 600; text-transform: uppercase; transition: 0.3s; }
        nav ul li a:hover { color: var(--accent-green); text-shadow: 0 0 10px rgba(85, 240, 180, 0.5); }

        /* --- Hero Section --- */
        .hero { min-height: 100vh; display: flex; align-items: center; padding: 100px 10% 50px; gap: 50px; position: relative; }
        .hero-text { flex: 1.2; z-index: 2; }
        .hero-text h4 { color: var(--accent-green); letter-spacing: 3px; margin-bottom: 15px; font-weight: 400; }
        .hero-text h1 { font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 900; line-height: 1.1; margin-bottom: 25px; }
        .hero-text h1 span { color: var(--accent-green); }
        .btn-main { background: var(--accent-green); color: var(--bg-dark); padding: 15px 35px; border-radius: 4px; text-decoration: none; font-weight: 700; text-transform: uppercase; font-size: 0.85rem; display: inline-block; transition: 0.4s; border: 2px solid var(--accent-green); }
        .btn-main:hover { background: transparent; color: var(--accent-green); box-shadow: 0 10px 20px rgba(85, 240, 180, 0.2); transform: translateY(-3px); }

        /* --- Hexagon Profile --- */
        .hero-image { flex: 0.8; z-index: 2; display: flex; justify-content: center; }
        .hexagon-shape { 
            width: 320px; height: 370px; background: var(--accent-green); 
            clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%); 
            display: flex; justify-content: center; align-items: center;
            animation: pulsing 3s ease-in-out infinite;
        }
        .hexagon-inner { 
            width: 96%; height: 96%; background: var(--bg-dark); 
            clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%); 
            overflow: hidden; 
        }
        .hexagon-inner img { width: 100%; height: 100%; object-fit: cover; transition: 0.5s; }
        .hexagon-inner img:hover { transform: scale(1.1); }

        @keyframes pulsing {
            0%, 100% { transform: scale(1); filter: drop-shadow(0 0 5px var(--accent-green)); }
            50% { transform: scale(1.03); filter: drop-shadow(0 0 20px var(--accent-green)); }
        }

        /* --- Section Styling --- */
        .section { padding: 100px 10%; }
        .section-header { margin-bottom: 60px; text-align: center; }
        .section-header h2 { font-size: 2.8rem; font-weight: 800; }
        .section-header h2 span { color: var(--accent-green); }

        /* --- About Me Section --- */
        .about-container {
            display: flex; align-items: center; gap: 60px;
            background: var(--glass); padding: 50px; border-radius: 30px;
            border: 1px solid rgba(255,255,255,0.05); backdrop-filter: blur(10px);
        }
        .about-img { flex: 1; position: relative; }
        .about-img img { width: 100%; border-radius: 20px; filter: grayscale(20%); transition: 0.5s; }
        .about-img::after {
            content: ''; position: absolute; top: 20px; left: 20px; width: 100%; height: 100%;
            border: 2px solid var(--accent-green); border-radius: 20px; z-index: -1;
        }
        .about-content { flex: 1.5; }
        .about-content h3 { font-size: 1.8rem; margin-bottom: 20px; }
        .about-content p { color: var(--text-dim); line-height: 1.8; margin-bottom: 25px; font-size: 0.95rem; }
        .about-features { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .feature-item { display: flex; align-items: center; gap: 10px; color: var(--text-main); font-weight: 500; font-size: 0.9rem; }
        .feature-item i { color: var(--accent-green); }

        /* --- Skills Grid --- */
        .skills-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 20px; }
        .skill-card { 
            background: var(--bg-card); padding: 35px 20px; border-radius: 20px; 
            text-align: center; border: 1px solid rgba(255,255,255,0.03); transition: 0.4s;
        }
        .skill-card:hover { 
            background: linear-gradient(145deg, var(--bg-card), #252b36);
            border-color: var(--accent-green); transform: translateY(-10px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }
        .skill-card i { font-size: 3rem; color: var(--accent-green); margin-bottom: 15px; display: block; }
        .skill-card span { font-weight: 600; letter-spacing: 1px; }

        /* --- Projects Grid (5 Items) --- */
        .projects-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 30px; }
        .project-card { 
            background: var(--bg-card); border-radius: 20px; overflow: hidden; 
            position: relative; border: 1px solid rgba(255,255,255,0.03); transition: 0.4s;
        }
        .project-card:hover { transform: translateY(-10px); border-color: var(--accent-green); }
        .project-img-wrapper { overflow: hidden; position: relative; height: 240px; }
        .project-card img { width: 100%; height: 100%; object-fit: cover; transition: 0.6s; }
        .project-overlay {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(18, 20, 29, 0.9); display: flex; justify-content: center;
            align-items: center; opacity: 0; transition: 0.4s;
        }
        .project-card:hover .project-overlay { opacity: 1; }
        .project-card:hover img { transform: scale(1.1); }
        .view-btn { border: 2px solid var(--accent-green); color: var(--accent-green); padding: 10px 25px; border-radius: 50px; text-decoration: none; font-weight: 600; transition: 0.3s; }
        .view-btn:hover { background: var(--accent-green); color: var(--bg-dark); }

        .project-info { padding: 25px; }
        .project-info h3 { color: var(--accent-green); margin-bottom: 10px; font-size: 1.3rem; }
        .project-info p { color: var(--text-dim); font-size: 0.85rem; line-height: 1.6; }

        /* --- Contact Box --- */
        .contact-box {
            display: flex; flex-wrap: wrap; border-radius: 30px; overflow: hidden;
            box-shadow: 0 25px 60px rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.05);
        }
        .contact-info-side { flex: 1; min-width: 320px; background: var(--bg-contact-left); padding: 60px; }
        .contact-info-side h3 { font-size: 1.8rem; margin-bottom: 15px; }
        .contact-item { display: flex; align-items: center; gap: 15px; margin-bottom: 25px; color: var(--text-dim); text-decoration: none; transition: 0.3s; }
        .contact-item:hover { color: var(--accent-green); }
        .contact-item i { color: var(--accent-green); font-size: 1.3rem; }

        .contact-form-side { flex: 1.3; min-width: 320px; padding: 60px; background: #161b22; }
        .form-control { width: 100%; background: rgba(255,255,255,0.03); border: 1px solid #333; padding: 18px; color: #fff; border-radius: 12px; margin-bottom: 20px; transition: 0.3s; }
        .form-control:focus { border-color: var(--accent-green); outline: none; background: rgba(255,255,255,0.06); }
        .btn-send { width: 100%; background: var(--accent-green); color: var(--bg-dark); padding: 18px; border: none; border-radius: 12px; font-weight: 700; cursor: pointer; transition: 0.3s; text-transform: uppercase; letter-spacing: 1px; }
        .btn-send:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(85, 240, 180, 0.2); opacity: 0.9; }

        footer { text-align: center; padding: 50px; color: var(--text-dim); background: #0b0d11; border-top: 1px solid rgba(255,255,255,0.03); }

        /* Responsive */
        @media (max-width: 900px) {
            .hero, .about-container { flex-direction: column; text-align: center; }
            .about-img::after { display: none; }
            .about-features { grid-template-columns: 1fr; text-align: left; max-width: 250px; margin: 0 auto; }
            nav ul { display: none; }
            .section { padding: 80px 5%; }
        }
    </style>
</head>
<body>

    <header>
        <div class="logo">MFAD</div>
        <nav>
            <ul>
                <li><a href="#home">Home</a></li>
                <li><a href="#about">About</a></li>
                <li><a href="#skills">Skills</a></li>
                <li><a href="#work">Projects</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
        </nav>
    </header>

    <section id="home" class="hero">
        <div class="hero-text" data-aos="fade-right">
            <h4>DEVELOPER,DESIGNER DAN Hardware</h4>
            <h1>CREATIVE <span>PLAYER</span></h1>
            <p>UI/UX Designer, Web Developer, dan Hardware Enthusiast. Fokus menciptakan pengalaman digital yang menarik dan solusi teknis yang inovatif.</p>
            <br>
            <a href="#work" class="btn-main">Projects Saya</a>
        </div>
        <div class="hero-image" data-aos="zoom-in">
            <div class="hexagon-shape">
                <div class="hexagon-inner">
                    <img src="MUHAMMAD FAKHRI ALMER DZAKY (1).png" alt="Almer Fakhri">
                </div>
            </div>
        </div>
    </section>

    <section id="about" class="section" style="background: #0b0d11;">
        <div class="section-header" data-aos="fade-up">
            <h2>About <span>Me</span></h2>
        </div>
        <div class="about-container" data-aos="fade-up">
            <div class="about-img">
                <img src="hhg.jpeg" alt="About Almer">
            </div>
            <div class="about-content">
                <h3>Membangun Masa Depan Melalui Kode, Desain Dan Hardware.</h3>
                <p>Halo Saya seorang Mahasiswa Dari Sekolah SMK Metland Scholl Jutrusan PPLG (Pengembangan Perangkat Lunak dan Gim). Saya memiliki hasrat besar dalam menggabungkan estetika desain UI/UX dengan fungsionalitas pemrograman web serta keandalan hardware.</p>
                <p>Setiap proyek bagi saya adalah kesempatan untuk belajar hal baru dan memberikan solusi kreatif yang memudahkan pengguna.</p>
                <div class="about-features">
                    <div class="feature-item"><i class="fas fa-check-circle"></i> Berorientasi Detail</div>
                    <div class="feature-item"><i class="fas fa-check-circle"></i> Problem Solver</div>
                    <div class="feature-item"><i class="fas fa-check-circle"></i> Desain Modern</div>
                    <div class="feature-item"><i class="fas fa-check-circle"></i> Hardware Expert</div>
                </div>
            </div>
        </div>
    </section>

    <section id="skills" class="section">
        <div class="section-header" data-aos="fade-up">
            <h2>Technical <span>Skills</span></h2>
        </div>
        <div class="skills-grid">
            <div class="skill-card" data-aos="flip-left"><i class="fab fa-html5"></i><span>HTML</span></div>
            <div class="skill-card" data-aos="flip-left" data-aos-delay="100"><i class="fab fa-css3-alt"></i><span>CSS</span></div>
            <div class="skill-card" data-aos="flip-left" data-aos-delay="200"><i class="fab fa-js"></i><span>JavaScript</span></div>
            <div class="skill-card" data-aos="flip-left" data-aos-delay="300"><i class="fab fa-figma"></i><span>Figma</span></div>
            <div class="skill-card" data-aos="flip-left" data-aos-delay="400"><i class="fas fa-microchip"></i><span>Hardware</span></div>
        </div>
    </section>

    <section id="work" class="section" style="background: #0b0d11;">
        <div class="section-header" data-aos="fade-up">
            <h2>Featured <span>Projects</span></h2>
        </div>
        <div class="projects-grid">
            <div class="project-card" data-aos="fade-up">
                <div class="project-img-wrapper">
                    <img src="alat rumah.png" alt="Furniture Web">
                    <div class="project-overlay"></div>
                </div>
                <div class="project-info">
                    <h3> Furnitur Penjualan Alat Rumah Tangga</h3>
                    <p>berbasis Fiqma dengan tampilan modern dan sistem.</p>
                </div>
            </div>
            <div class="project-card" data-aos="fade-up" data-aos-delay="100">
                <div class="project-img-wrapper">
                    <img src="Bell.jpeg" alt="Bel Otomatis">
                    <div class="project-overlay"></div>
                </div>
                <div class="project-info">
                    <h3>Bel Otomatis PJBL</h3>
                    <p>Sistem otomatisasi waktu sekolah menggunakan integrasi hardware Arduino/ESP dan software.</p>
                </div>
            </div>
            <div class="project-card" data-aos="fade-up" data-aos-delay="200">
                <div class="project-img-wrapper">
                    <img src="Shopee.png" alt="PPDB System">
                    <div class="project-overlay"></div>
                </div>
                <div class="project-info">
                    <h3>Tampilan Web shopee</h3>
                    <p>Mengembangkan tampilan antarmuka (Front-End) situs belanja online dengan fokus pada kemiripan visual dan fungsionalitas navigas</p>
                </div>
            </div>
            <div class="project-card" data-aos="fade-up">
                <div class="project-img-wrapper">
                    <img src="buku.png" alt="E-Book App">
                    <div class="project-overlay"></div>
                </div>
                <div class="project-info">
                    <h3>E-Book Elektronika</h3>
                    <p>Aplikasi edukatif interaktif mengenai pengenalan komponen dasar elektronika.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="contact" class="section">
        <div class="contact-box" data-aos="zoom-in">
            <div class="contact-info-side">
                <h3>Get In Touch</h3>
                <p>Tertarik untuk bekerjasama atau hanya ingin menyapa?</p>
                <br>
                <div class="contact-item"><i class="fas fa-map-marker-alt"></i> Metland Cilengsi Sektor 3 Jl Metlan Raya 2 No 2 Blok CL 2 Cipenjo</div>
                <div class="contact-item"><i class="fas fa-envelope"></i> fakhrialmer703@email.com</div>
                <a href="#" class="contact-item"><i class="fab fa-github"></i> fakhrialmer703-sketch</a>
                <a href="#" class="contact-item"><i class="fab fa-whatsapp"></i> 0885692130289</a>
            </div>
            <div class="contact-form-side">
                <form id="contactForm">
                    <input type="text" class="form-control" placeholder="Nama Lengkap" required>
                    <input type="email" class="form-control" placeholder="Alamat Email" required>
                    <textarea class="form-control" rows="5" placeholder="Pesan Anda" required></textarea>
                    <button type="submit" class="btn-send">Kirim Pesan Sekarang</button>
                </form>
            </div>
        </div>
    </section>

    <footer>
        <p>&copy; 2026 Almer Fakhri. Dibuat dengan <i class="fas fa-heart" style="color: var(--accent-green); margin: 0 5px;"></i> di Jawa Barat.</p>
    </footer>

    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        // Inisialisasi Animasi Scroll
        AOS.init({
            duration: 1000,
            once: true,
            offset: 100
        });

        // Contoh penanganan form sederhana
        document.getElementById('contactForm').addEventListener('submit', function(e) {
            e.preventDefault();
            alert('Terima kasih! Pesan Anda telah terkirim (Ini hanya simulasi).');
            this.reset();
        });
    </script>
</body>
</html>
